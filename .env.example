APP_NAME=SuGanta_API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Frontend URL for password reset links and redirects
FRONTEND_URL=https://www.suganta.com
# Payment callback status page "Go Back" button URL (optional)
PAYMENT_GO_BACK_URL=https://www.suganta.com

# API (optional: used by config/api.php)
# API_VERSION=v1
# API_RATE_LIMIT=60,1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Share session cookie across api.suganta.com + app.suganta.com (production)
SESSION_DOMAIN=null
# SESSION_DOMAIN=.suganta.com

# Sanctum: browser SPA origins that may use cookie + CSRF session auth (comma-separated, no scheme)
# Include the web app host (e.g. app.suganta.com) plus local dev ports as needed
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,app.suganta.com

# CORS: required when SPA on app.* calls API on api.* with credentials: 'include' (cannot use *)
# CORS_ALLOWED_ORIGINS=https://app.suganta.com,http://localhost:3000
# CORS_SUPPORTS_CREDENTIALS=true

# When true, API requests with Authorization: Bearer <non-empty> skip CSRF (token auth).
# SANCTUM_CSRF_SKIP_WITH_BEARER=true
# When true, all /api/* routes skip CSRF so session cookies work without X-XSRF-TOKEN (split SPA + API hosts).
# SANCTUM_CSRF_EXEMPT_API=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Upload disk: public (local) | s3 (AWS) | gcs (GCP) - change only this to switch storage
FILESYSTEM_UPLOAD_DISK=public
QUEUE_CONNECTION=database
# Laravel queue rows — keep separate from the employment `jobs` listings table
DB_QUEUE_TABLE=queue_jobs
# Optional: DB_QUEUE_CONNECTION=mysql
# Optional: DB_QUEUE=default
# Failed jobs DB table (use queue_failed_jobs only if you migrated that name instead of failed_jobs)
# QUEUE_FAILED_TABLE=failed_jobs

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
V4_GOOGLE_CACHE_STORE=redis
V4_GOOGLE_CALENDAR_CACHE_TTL_SECONDS=60
V4_GOOGLE_YOUTUBE_CACHE_TTL_SECONDS=120
V4_GOOGLE_DRIVE_CACHE_TTL_SECONDS=90

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# GCP Cloud Storage (when FILESYSTEM_UPLOAD_DISK=gcs)
# GCP_PROJECT_ID=your-project-id
# GCP_KEY_FILE=storage/keys/gcp-service-account.json
# GCP_BUCKET=your-bucket-name
# GCP_PATH_PREFIX=                           # optional: prefix inside bucket
# GCP_STORAGE_API_URI=                       # optional: custom domain for URLs
# GCP_UNIFORM_BUCKET_ACCESS=false            # set true if bucket uses uniform bucket-level access

REVERB_APP_ID=suganta-chat
REVERB_APP_KEY=suganta-reverb-key-2026
REVERB_APP_SECRET=suganta-reverb-secret-2026
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"

SMS_COUNTRY_AUTH_KEY=
SMS_COUNTRY_AUTH_TOKEN=
SMS_COUNTRY_BASE_URL="https://restapi.smscountry.com/v0.1/Accounts/AUTH_KEY/SMSes/"
SMS_COUNTRY_SENDER_ID=

# Firebase Cloud Messaging (server-side push)
# Example (Windows): C:\path\to\firebase-service-account.json
# FIREBASE_PROJECT_ID=your-firebase-project-id   # optional; auto-detected from service account when empty
FIREBASE_CREDENTIALS=storage/keys/suganta-tutors-firebase-adminsdk-fbsvc-51a7fa7774.json
PUSH_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_CHAT_ENABLED=true
PUSH_CHAT_EVENT_NEW_MESSAGE=true
PUSH_CHAT_EVENT_MESSAGE_EDITED=true
PUSH_CHAT_EVENT_MESSAGE_DELETED=true
PUSH_CHAT_EVENT_MESSAGE_READ=false
PUSH_CHAT_EVENT_REACTION_ADDED=true
PUSH_CHAT_EVENT_REACTION_REMOVED=true
PUSH_MODEL_ACTIVITY_ENABLED=true
PUSH_MODEL_ACTIVITY_SEND_TO_ALL=true
PUSH_MODEL_ACTIVITY_COOLDOWN_SECONDS=120

# Gemini AI configuration
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash-lite

# Google APIs (v4 integration)
GOOGLE_API_TIMEOUT_SECONDS=15
GOOGLE_OAUTH_CLIENT_JSON=storage/keys/suganta-sync.json
# Optional fallback (only if JSON file is not available)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_REDIRECT_URI=http://localhost/api/v4/google/oauth/callback
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_DEFAULT_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/youtube.readonly,https://www.googleapis.com/auth/userinfo.email
GOOGLE_WEBHOOK_URL=
GOOGLE_WEBHOOK_SECRET=
GOOGLE_WEBHOOK_REPLAY_WINDOW_SECONDS=300
GOOGLE_WATCH_TOKEN_TTL_SECONDS=86400
GOOGLE_WATCH_RENEW_BEFORE_SECONDS=900
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3
GOOGLE_YOUTUBE_BASE_URL=https://www.googleapis.com/youtube/v3
GOOGLE_DRIVE_BASE_URL=https://www.googleapis.com/drive/v3

# AI usage & limits
AI_ADVISER_SYSTEM_USER_ID=
AI_FREE_TOKENS=100000
AI_SUBSCRIPTION_TYPE=3

# Prompt / response optimization
GEMINI_HISTORY_LIMIT=10
GEMINI_HISTORY_MESSAGE_MAX_CHARS=800
GEMINI_MAX_OUTPUT_TOKENS=500

# ─── Chatbot Automation (Meta Graph API) ───────────────
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_IG_PAGE_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=suganta_chatbot_verify_2026
META_API_VERSION=v19.0

# Chatbot AI Fallback Provider (gemini or grok)
CHATBOT_AI_PROVIDER=gemini
CHATBOT_FALLBACK_MESSAGE="Thanks for reaching out to SuGanta! Our team will get back to you shortly."
CHATBOT_WELCOME_MESSAGE="Welcome to SuGanta! I'm here to help you find the best tutors and courses."
CHATBOT_RESPONSE_TIMEOUT=2000
CHATBOT_CACHE_TTL=3600
CHATBOT_WEBHOOK_RATE_LIMIT=120

