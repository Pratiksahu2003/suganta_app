APP_NAME=SuGanta_API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Frontend URL for password reset links and redirects
FRONTEND_URL=https://www.suganta.com

# API (optional: used by config/api.php)
# API_VERSION=v1
# API_RATE_LIMIT=60,1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Upload disk: public (local) | s3 (AWS) | gcs (GCP) - change only this to switch storage
FILESYSTEM_UPLOAD_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# GCP Cloud Storage (when FILESYSTEM_UPLOAD_DISK=gcs)
# GCP_PROJECT_ID=your-project-id
# GCP_KEY_FILE=storage/keys/gcp-service-account.json
# GCP_BUCKET=your-bucket-name
# GCP_PATH_PREFIX=                           # optional: prefix inside bucket
# GCP_STORAGE_API_URI=                       # optional: custom domain for URLs
# GCP_UNIFORM_BUCKET_ACCESS=false            # set true if bucket uses uniform bucket-level access

VITE_APP_NAME="${APP_NAME}"

SMS_COUNTRY_AUTH_KEY=
SMS_COUNTRY_AUTH_TOKEN=
SMS_COUNTRY_BASE_URL="https://restapi.smscountry.com/v0.1/Accounts/AUTH_KEY/SMSes/"
SMS_COUNTRY_SENDER_ID=
