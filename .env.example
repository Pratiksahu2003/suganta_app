APP_NAME=SuGanta_API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Frontend URL for password reset links and redirects
FRONTEND_URL=https://www.suganta.com

# API (optional: used by config/api.php)
# API_VERSION=v1
# API_RATE_LIMIT=60,1

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Upload disk: public (local) | s3 (AWS) | gcs (GCP) - change only this to switch storage
FILESYSTEM_UPLOAD_DISK=public
QUEUE_CONNECTION=database
# Laravel queue rows — keep separate from the employment `jobs` listings table
DB_QUEUE_TABLE=queue_jobs
# Optional: DB_QUEUE_CONNECTION=mysql
# Optional: DB_QUEUE=default
# Failed jobs DB table (use queue_failed_jobs only if you migrated that name instead of failed_jobs)
# QUEUE_FAILED_TABLE=failed_jobs

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# GCP Cloud Storage (when FILESYSTEM_UPLOAD_DISK=gcs)
# GCP_PROJECT_ID=your-project-id
# GCP_KEY_FILE=storage/keys/gcp-service-account.json
# GCP_BUCKET=your-bucket-name
# GCP_PATH_PREFIX=                           # optional: prefix inside bucket
# GCP_STORAGE_API_URI=                       # optional: custom domain for URLs
# GCP_UNIFORM_BUCKET_ACCESS=false            # set true if bucket uses uniform bucket-level access

REVERB_APP_ID=suganta-chat
REVERB_APP_KEY=suganta-reverb-key-2026
REVERB_APP_SECRET=suganta-reverb-secret-2026
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_APP_NAME="${APP_NAME}"

SMS_COUNTRY_AUTH_KEY=
SMS_COUNTRY_AUTH_TOKEN=
SMS_COUNTRY_BASE_URL="https://restapi.smscountry.com/v0.1/Accounts/AUTH_KEY/SMSes/"
SMS_COUNTRY_SENDER_ID=

# Firebase Cloud Messaging (server-side push)
# Example (Windows): C:\path\to\firebase-service-account.json
# FIREBASE_PROJECT_ID=your-firebase-project-id   # optional; auto-detected from service account when empty
FIREBASE_CREDENTIALS=storage/keys/suganta-tutors-firebase-adminsdk-fbsvc-51a7fa7774.json
PUSH_ENABLED=true
PUSH_NOTIFICATIONS_ENABLED=true
PUSH_CHAT_ENABLED=true
PUSH_CHAT_EVENT_NEW_MESSAGE=true
PUSH_CHAT_EVENT_MESSAGE_EDITED=true
PUSH_CHAT_EVENT_MESSAGE_DELETED=true
PUSH_CHAT_EVENT_MESSAGE_READ=false
PUSH_CHAT_EVENT_REACTION_ADDED=true
PUSH_CHAT_EVENT_REACTION_REMOVED=true
PUSH_MODEL_ACTIVITY_ENABLED=true
PUSH_MODEL_ACTIVITY_SEND_TO_ALL=true
PUSH_MODEL_ACTIVITY_COOLDOWN_SECONDS=120

# Gemini AI configuration
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash-lite

# AI usage & limits
AI_ADVISER_SYSTEM_USER_ID=
AI_FREE_TOKENS=100000
AI_SUBSCRIPTION_TYPE=3

# Prompt / response optimization
GEMINI_HISTORY_LIMIT=10
GEMINI_HISTORY_MESSAGE_MAX_CHARS=800
GEMINI_MAX_OUTPUT_TOKENS=500
